PORT=8001
DEBUG=True

# AI Models Config
OPENAI_API_KEY=your_openai_api_key
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=your_region_name
AWS_STORAGE_BUCKET_NAME=your_bucket_name
GOOGLE_API_KEY=your_google_api_key
OPENAI_MODEL_ID=gpt-4o-mini
GEMINI_MODEL_ID_TEXT=gemini-2.5-flash
GEMINI_MODEL_ID_IMAGES=gemini-2.5-flash-image

# Default Provider: openai | gemini
IMAGE_GEN_PROVIDER=gemini

# Database/Persistence
CHROMA_PERSIST_DIR=./data/chroma
PROJECT_DATA_DIR=./data/projects

# Backend Callback URL (Legacy, now using SQS)
AWS_SQS_QUEUE_URL=your_sqs_queue_url

# LangSmith Observability - draft-comic
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=draft-comic

# Performance / observability tuning
# Start with concurrency = 2 and move to 3 only if the run stays stable.
# Higher values can increase provider/API pressure and make LangSmith traces noisier.

# 1 = print TIMING logs per node/substep, 0 = disable timing logs.
# Try: 1 or 0
COMIC_AGENT_TIMING=1

# 1 = save canon once at the end of world_model_builder, 0 = legacy save on each update.
# Try: 1 or 0
ENABLE_BATCH_CANON_SAVE=1

# 1 = process story_understanding batches in parallel, 0 = legacy sequential mode.
# Try: 1 or 0
ENABLE_PARALLEL_STORY=1

# Number of workers for story_understanding batches.
# Safe start: 2 | Common test range: 1-3
STORY_BATCH_CONCURRENCY=2

# 1 = extract character/scenery visual traits in parallel, 0 = legacy sequential mode.
# Try: 1 or 0
ENABLE_PARALLEL_WORLD_TRAITS=1

# Number of workers for visual trait extraction jobs.
# Safe start: 2 | Common test range: 1-3
WORLD_TRAITS_CONCURRENCY=2

# 1 = force re-extract traits even if canon already has them, 0 = reuse existing traits.
# Use 1 mainly for verification/debug; use 0 in normal runs.
FORCE_WORLD_TRAITS_REFRESH=1

# 1 = parallelize prompt_build + image render per panel after sequential continuity prepass.
# 0 = keep generator fully sequential.
# Try: 1 or 0
ENABLE_PARALLEL_GENERATOR=1

# Number of workers for panel jobs in image_generator.
# Safe start: 2 | Common test range: 1-3
GENERATOR_CONCURRENCY=2
